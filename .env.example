APP_NAME=CRA Backend
APP_VERSION=2.0.0
DEBUG=True
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./cra.db

SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Microsoft Entra ID — from Azure Portal App Registration
AZURE_CLIENT_ID=702eb094-c0a3-4950-bdab-ca97d2c256be
AZURE_TENANT_ID=common

# Organization
ORGANIZATION_NAME=Your Organization Name

# Optional Phase 4+ (server-side MSAL / Graph only — never put secret in frontend)
# AZURE_CLIENT_SECRET=your-client-secret-value
# AZURE_CLIENT_SECRET_ID=your-secret-id-from-azure-portal
# AZURE_AUTHORITY=https://login.microsoftonline.com/common
# AZURE_REDIRECT_URI=http://localhost:3000/auth/callback
